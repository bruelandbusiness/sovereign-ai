# ============================================================================
# Sovereign AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================================

# ── Required Always ─────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/sovereign_ai"

# Auth secret — minimum 32 characters. Generate with: openssl rand -base64 32
AUTH_SECRET="change-in-production-minimum-32-chars"

# ── Required in Production ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
CRON_SECRET="your-cron-secret"
SENDGRID_API_KEY="SG...."

# ── Required in Production ─────────────────────────────────────────────────
API_URL="https://api.sovereignai.com"

# ── Optional with Defaults ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL=""
