# ============================================
# Sovereign AI — Next.js Environment Variables
# ============================================

# Backend API URL — where the Python FastAPI server runs
# Local development: http://localhost:8000
# Production: your deployed backend URL (e.g. https://api.sovereignai.com)
API_URL=http://localhost:8000

# Public API URL for client-side calls
# Leave empty to use Next.js API routes as proxy (recommended)
NEXT_PUBLIC_API_URL=

# Database — SQLite for local dev, can switch to Postgres in production
DATABASE_URL="file:./dev.db"

# Auth — secret for session tokens (change in production!)
AUTH_SECRET=change-me-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic — for AI chatbot and content generation
ANTHROPIC_API_KEY=

# SendGrid — for magic link emails, review requests, welcome emails
# Falls back to console.log in dev if not set
SENDGRID_API_KEY=
FROM_EMAIL=noreply@sovereignai.com

# ============================================
# Python Backend Variables (set in backend/.env)
# ============================================
# SERPAPI_KEY=           — Google Maps/Search scraping
# STRIPE_SECRET_KEY=     — Stripe secret key (sk_live_...)
# STRIPE_WEBHOOK_SECRET= — Stripe webhook signing secret
# DOMAIN=                — Your domain (https://sovereignai.com)
# CALENDLY_LINK=         — Strategy call booking URL
# TELEGRAM_BOT_TOKEN=    — Telegram notifications bot token
# TELEGRAM_CHAT_ID=      — Your Telegram chat ID
