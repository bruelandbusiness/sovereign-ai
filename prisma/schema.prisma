  paidAt      DateTime?
  createdAt   DateTime @default(now())

  affiliate AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
}

model ProspectLead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  source      String   // vsl | audit | partner | clay | organic
  trade       String?  // hvac | plumbing | roofing | etc.
  partnerSlug String?  // if referred by a partner
  referralCode String? // affiliate referral code
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  metadata    Json?    // extra data (audit score, Clay enrichment, etc.)
  status      String   @default("new") // new | contacted | booked | converted | lost
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([source])
  @@index([partnerSlug])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// P0: COMPLIANCE ENGINE
// ═══════════════════════════════════════════════════════════════

model ComplianceConfig {
  id                  String   @id @default(cuid())
  clientId            String   @unique
  physicalAddress     String   // Required for CAN-SPAM footer
  fromName            String   // Must accurately identify sender
  fromEmail           String   // Must be valid, monitored mailbox
  tcpaConsentRequired Boolean  @default(true)
  smsQuietStartHour   Int      @default(8)  // 8 AM local
  smsQuietEndHour     Int      @default(21) // 9 PM local
  timezone            String   @default("America/Chicago")
  maxContactAttempts  Int      @default(3)
  cooldownDays        Int      @default(30)
  dataPurgeDays       Int      @default(90) // unconverted lead purge threshold
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ConsentRecord {
  id            String    @id @default(cuid())
  clientId      String
  contactPhone  String?
  contactEmail  String?
  channel       String    // sms | email | voice
  consentType   String    // express_written | opt_in | implied
  consentSource String    // form | chatbot | api | manual | discovery
  consentText   String?   // The actual disclosure shown to the contact
  ipAddress     String?
  consentedAt   DateTime  @default(now())
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([contactPhone])
  @@index([contactEmail])
  @@index([channel])
}

model SuppressionList {
  id           String   @id @default(cuid())
  clientId     String?  // null = global suppression
  contactPhone String?
  contactEmail String?
  channel      String   // sms | email | voice | all
  reason       String   // unsubscribe | bounce | complaint | stop | dnc | manual
  source       String?  // webhook | inbound_sms | manual | cron
  createdAt    DateTime @default(now())

  client Client? @relation("ClientSuppression", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([contactEmail])
  @@index([contactPhone])
  @@index([channel])
  @@index([clientId])
}

model ContactAttemptLog {
  id           String   @id @default(cuid())
  clientId     String
  contactPhone String?
  contactEmail String?
  channel      String   // sms | email | voice
  status       String   // sent | blocked | failed
  blockReason  String?  // suppressed | no_consent | quiet_hours | cooldown | dnc | budget
  createdAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([contactPhone, createdAt])
  @@index([contactEmail, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// P1: LEAD DISCOVERY ENGINE
// ═══════════════════════════════════════════════════════════════

model DiscoverySource {
  id             String    @id @default(cuid())
  clientId       String
  type           String    // permit | real_estate | competitor_review | seasonal | aging_home
  name           String
  config         String?   // JSON: { county, state, permitTypes[], lookbackDays, ... }
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  lastRunStatus  String?   // success | error | partial
  lastRunError   String?
  lastRunCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  discoveredLeads DiscoveredLead[]

  @@index([clientId])
  @@index([type])
}

model DiscoveredLead {
  id               String    @id @default(cuid())
  clientId         String
  sourceId         String
  sourceType       String    // permit | real_estate | competitor_review | seasonal | aging_home
  externalId       String?   // Dedupe key from source
  propertyAddress  String?
  ownerName        String?
  ownerEmail       String?
  ownerPhone       String?
  propertyAge      Int?      // years
  propertyType     String?
  saleDate         DateTime?
  salePrice        Int?      // cents
  permitType       String?
  permitDate       DateTime?
  reviewPlatform   String?
  reviewRating     Int?
  reviewSnippet    String?
  competitorName   String?
  seasonalTrigger  String?   // JSON: { season, weatherEvent, demandType }
  rawData          String?   // JSON: full source record
  discoveryScore   Int?      // 0-100 based on signal strength
  status           String    @default("new") // new | enriching | converted | discarded | duplicate
  convertedLeadId  String?   // FK to Lead once converted
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source DiscoverySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([clientId, sourceType, externalId])
  @@index([clientId])
  @@index([sourceId])
  @@index([status])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// P2: LEAD ENRICHMENT PIPELINE
// ═══════════════════════════════════════════════════════════════

model EnrichmentRecord {
  id               String    @id @default(cuid())
  clientId         String
  leadId           String?
  discoveredLeadId String?
  status           String    @default("pending") // pending | enriching | complete | failed | partial
  addressInput     String?
  ownerName        String?
  mailingAddress   String?
  emailFound       String?
  emailVerified    Boolean   @default(false)
  emailSource      String?   // hunter | snov | clearbit | manual
  phoneFound       String?
  phoneLineType    String?   // mobile | landline | voip
  phoneVerified    Boolean   @default(false)
  socialProfiles   String?   // JSON: { linkedin?, facebook?, twitter? }
  propertyAge      Int?
  propertyValue    Int?      // cents
  lastPermitDate   DateTime?
  lastPermitType   String?
  enrichedAt       DateTime?
  rawData          String?   // JSON: full enrichment response
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([leadId])
  @@index([discoveredLeadId])
  @@index([status])
}

model EnrichmentProvider {
  id          String   @id @default(cuid())
  name        String   @unique // reverse_address | email_finder | phone_lookup | social_match
  provider    String   // clearbit | hunter | twilio_lookup | pipl | etc.
  isActive    Boolean  @default(true)
  apiKeyEnv   String   // env var name holding the API key
  rateLimit   Int      @default(100) // requests per hour
  costPerCall Int      @default(0)   // cents
  config      String?  // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// P3: COLD OUTREACH PIPELINE
// ═══════════════════════════════════════════════════════════════

model OutreachDomain {
  id               String   @id @default(cuid())
  clientId         String
  domain           String
  dailyLimit       Int      @default(20)  // starts at 20 for warmup
  currentDailySent Int      @default(0)
  warmupStartDate  DateTime @default(now())
  warmupComplete   Boolean  @default(false)
  rampRate         Int      @default(10)  // increase per day
  maxDailyLimit    Int      @default(200)
  reputation       String   @default("warming") // warming | warm | hot | degraded
  lastResetAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, domain])
  @@index([clientId])
}

model OutreachSequence {
  id       String  @id @default(cuid())
  clientId String
  name     String
  channel  String  @default("email") // email | sms | multi
  isActive Boolean @default(true)
  steps    String  // JSON: [{ dayOffset, channel, templateKey, subject? }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entries OutreachEntry[]

  @@index([clientId])
}

model OutreachEntry {
  id               String    @id @default(cuid())
  clientId         String
  sequenceId       String
  leadId           String?
  discoveredLeadId String?
  contactEmail     String?
  contactPhone     String?
  contactName      String?
  currentStep      Int       @default(0)
  status           String    @default("active") // active | paused | completed | replied | unsubscribed | bounced
  lastStepAt       DateTime?
  nextStepAt       DateTime?
  personalizedData String?   // JSON: Claude-generated personalization
  engagementData   String?   // JSON: { opens: [], clicks: [], replies: [] }
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client   Client           @relation("ClientOutreachEntries", fields: [clientId], references: [id], onDelete: Cascade)
  sequence OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([sequenceId])
  @@index([status, nextStepAt])
  @@index([leadId])
  @@index([discoveredLeadId])
}

model SmsWarmupTracker {
  id               String   @id @default(cuid())
  clientId         String   @unique
  dailyLimit       Int      @default(50)
  currentDailySent Int      @default(0)
  warmupStartDate  DateTime @default(now())
  warmupComplete   Boolean  @default(false)
  rampRate         Int      @default(25)  // increase per day
  maxDailyLimit    Int      @default(500)
  lastResetAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// P4: FOLLOW-UP STATE MACHINE
// ═══════════════════════════════════════════════════════════════

model FollowUpSequence {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  triggerType String   // lead_captured | no_response | appointment_missed | post_service
  isActive    Boolean  @default(true)
  steps       String   // JSON: [{ dayOffset, channel, escalation, templateKey, condition? }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entries FollowUpEntry[]

  @@index([clientId])
}

model FollowUpEntry {
  id                  String    @id @default(cuid())
  clientId            String
  sequenceId          String
  leadId              String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  currentStep         Int       @default(0)
  currentChannel      String    @default("email") // email | sms | voice
  status              String    @default("active") // active | paused | completed | replied | converted | exhausted
  lastStepAt          DateTime?
  nextStepAt          DateTime?
  engagementLog       String?   // JSON: [{ type, channel, timestamp }]
  replyClassification String?   // hot_lead | interested | not_interested | unsubscribe | other
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client   Client           @relation("ClientFollowUpEntries", fields: [clientId], references: [id], onDelete: Cascade)
  sequence FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status, nextStepAt])
}

// ═══════════════════════════════════════════════════════════════
// P5: TELEGRAM BOT (OPERATOR CONTROL PLANE)
// ═══════════════════════════════════════════════════════════════

model TelegramConfig {
  id          String   @id @default(cuid())
  chatId      String   @unique // operator's Telegram chat ID
  accountId   String?  // linked account
  isActive    Boolean  @default(true)
  alertLevels String   @default("[\"critical\",\"revenue\"]") // JSON array of subscribed levels
  dailyDigest Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TelegramCommandLog {
  id        String   @id @default(cuid())
  chatId    String
  command   String
  args      String?
  response  String?
  createdAt DateTime @default(now())

  @@index([chatId])
}

// ═══════════════════════════════════════════════════════════════
// P6: ROI ATTRIBUTION
// ═══════════════════════════════════════════════════════════════

model ROIReport {
  id               String   @id @default(cuid())
  clientId         String
  periodType       String   // weekly | monthly
  periodStart      DateTime
  periodEnd        DateTime
  totalLeads       Int      @default(0)
  totalBookings    Int      @default(0)
  totalRevenue     Int      @default(0) // cents
  totalSpend       Int      @default(0) // cents (subscription + ad spend)
  roi              Float    @default(0) // (revenue - spend) / spend
  channelBreakdown String?  // JSON: [{ channel, leads, bookings, revenue }]
  sourceBreakdown  String?  // JSON: [{ source, leads, bookings, revenue }]
  generatedAt      DateTime @default(now())
  sentAt           DateTime?
  createdAt        DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([periodStart])
}

// ═══════════════════════════════════════════════════════════════
// P7: CLIENT ACQUISITION MACHINE
// ═══════════════════════════════════════════════════════════════

model Prospect {
  id               String    @id @default(cuid())
  businessName     String
  ownerName        String?
  email            String?
  phone            String?
  website          String?
  vertical         String?
  city             String?
  state            String?
  address          String?
  rating           Float?    // Google Maps rating (1-5)
  reviewCount      Int?      // Google Maps review count
  googleMapsUrl    String?
  placeId          String?   @unique // Google Maps place_id for dedup
  emailVerified    Boolean   @default(false)
  emailSource      String?   // hunter | website_scrape | manual
  estimatedRevenue Int?      // cents
  employeeCount    Int?
  techReadiness    Int?      // 0-100
  painSignals      String?   // JSON: [{ type, evidence, score }]
  budgetSignals    String?   // JSON: [{ type, evidence }]
  score            Int?      // 0-100 composite
  status           String    @default("new") // new | outreach | nurturing | demo | won | lost
  source           String?   // scrape | referral | inbound | manual
  outreachEntryId  String?   // link to outreach sequence if enrolled
  lastContactedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  activities ProspectActivity[]
  proposals  Proposal[]

  @@index([status])
  @@index([score])
  @@index([vertical])
  @@index([city, state])
  @@index([status, createdAt])
}

model ProspectActivity {
  id          String   @id @default(cuid())
  prospectId  String
  type        String   // email_sent | email_opened | call | demo | proposal | won | lost
  description String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
}

model CaseStudy {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  vertical    String?
  metrics     String   // JSON: { leadIncrease, revenueIncrease, roiPercent, timeframe }
  narrative   String?  // Claude-generated story
  isPublished Boolean  @default(false)
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([vertical])
}

model Proposal {
  id          String    @id @default(cuid())
  prospectId  String
  title       String
  content     String    // Claude-generated markdown/HTML
  pricing     String    // JSON: { bundle, monthlyAmount, setupFee, features[] }
  status      String    @default("draft") // draft | sent | viewed | accepted | rejected
  shareToken  String    @unique @default(cuid())
  sentAt      DateTime?
  viewedAt    DateTime?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
}

// ═══════════════════════════════════════════════════════════════
// COLD EMAIL OUTREACH SYSTEM (replaces Instantly.ai / Smartlead)
// ═══════════════════════════════════════════════════════════════

model ColdOutreachCampaign {
  id              String    @id @default(cuid())
  name            String
  status          String    @default("draft") // draft | active | paused | completed
  fromEmail       String
  fromName        String
  subjectVariants String    // JSON: string[] — A/B subject lines
  bodyTemplate    String    // HTML with {{name}}, {{company}}, {{vertical}}, {{city}} placeholders
  dailySendLimit  Int       @default(50)
  warmupEnabled   Boolean   @default(true)
  warmupStartSent Int       @default(5)   // emails/day to start warmup
  warmupRampRate  Int       @default(3)   // increase per day
  sequenceStep    Int       @default(1)   // which step in the 5-email sequence (1-5)
  dayOffset       Int       @default(0)   // day offset from enrollment (0, 3, 7, 14, 21)
  startedAt       DateTime?
  pausedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recipients ColdEmailRecipient[]

  @@index([status])
}

model ColdEmailRecipient {
  id           String    @id @default(cuid())
  campaignId   String
  email        String
  name         String?
  company      String?
  vertical     String?
  city         String?
  status       String    @default("pending") // pending | sent | opened | clicked | replied | bounced | unsubscribed
  trackingId   String    @unique @default(cuid()) // for open/click tracking
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  repliedAt    DateTime?
  bouncedAt    DateTime?
  subjectUsed  String?   // which A/B variant was sent
  clickUrl     String?   // original destination URL for click tracking
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  campaign ColdOutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@unique([campaignId, email])
}

// ─── Dashboard Snapshot ─────────────────────────────────────

model DashboardSnapshot {
  id             String   @id @default(cuid())
  clientId       String
  token          String   @unique
  businessName   String
  snapshotDate   DateTime @default(now())
  expiresAt      DateTime
  revoked        Boolean  @default(false)
  data           String   // JSON blob: KPIs, lead count, revenue, review score, active services
  viewCount      Int      @default(0)
  createdAt      DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
}
