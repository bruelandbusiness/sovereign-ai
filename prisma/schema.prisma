generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("client") // client | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  magicLinks       MagicLink[]
  sessions         Session[]
  client           Client?
  notifications    Notification[]
  mcpApiKeys       MCPApiKey[]
  pushSubscriptions PushSubscription[]
  communityPosts   CommunityPost[]
  communityComments CommunityComment[]
  productPurchases ProductPurchase[]
  productReviews   ProductReview[]
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  accountId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  accountId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

// ─── Client & Subscription ──────────────────────────────────

model Client {
  id                 String   @id @default(cuid())
  accountId          String   @unique
  agencyId           String?
  businessName       String
  ownerName          String
  phone              String?
  city               String?
  state              String?
  vertical           String?
  website            String?
  serviceAreaRadius  String?
  onboardingData     String?  // JSON blob of full onboarding form
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account              Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscription         Subscription?
  services             ClientService[]
  leads                Lead[]
  activities           ActivityEvent[]
  chatbotConfig        ChatbotConfig?
  reviewCampaigns      ReviewCampaign[]
  contentJobs          ContentJob[]
  emailCampaigns       EmailCampaign[]
  bookings             Booking[]
  onboardingSteps      OnboardingStep[]
  referralCodes        ReferralCode[]       @relation("referrer")
  referredBy           ReferralCode[]       @relation("referred")
  supportTickets       SupportTicket[]
  npsResponses         NPSResponse[]
  adCampaigns          AdCampaign[]
  agentExecutions      AgentExecution[]
  alertLogs            AnomalyLog[]
  approvalRequests     ApprovalRequest[]
  budgetTrackers       BudgetTracker[]
  callLogs             CallLog[]
  conversationThreads  ConversationThread[]
  customerLifetimeValues CustomerLifetimeValue[]
  customerReferrals    CustomerReferral[]
  fsmConnections       FSMConnection[]
  financingApplications FinancingApplication[]
  franchiseLocations   FranchiseLocation[]
  governanceRules      GovernanceRule[]
  invoices             Invoice[]
  jobPostings          JobPosting[]
  locations            Location[]
  missedCallTextbacks  MissedCallTextback[]
  performancePlan      PerformancePlan?
  performanceEvents    PerformanceEvent[]
  phoneCalls           PhoneCall[]
  photoEstimates       PhotoEstimate[]
  predictiveInsights   PredictiveInsight[]
  quotes               Quote[]
  receptionistConfig   ReceptionistConfig?
  revenueEvents        RevenueEvent[]
  reviewResponses      ReviewResponse[]
  seoKeywords          SEOKeyword[]
  seasonalCampaigns    SeasonalCampaign[]
  serviceAreas         ServiceArea[]
  serviceReminders     ServiceReminder[]
  socialPosts          SocialPost[]
  unifiedMessages      UnifiedMessage[]
  webhookEndpoints     WebhookEndpoint[]
  aeoStrategies        AEOStrategy[]
  aeoQueries           AEOQuery[]
  aeoContent           AEOContent[]
  clientBenchmarkScores ClientBenchmarkScore[]
  qbrReports           QBRReport[]
}

model Subscription {
  id              String    @id @default(cuid())
  clientId        String    @unique
  stripeSubId     String?   @unique
  stripeCustId    String?
  bundleId        String?   // "starter" | "growth" | "empire" | null for à la carte
  status          String    @default("active") // active | past_due | canceled | expired
  monthlyAmount   Int       @default(0) // cents
  currentPeriodEnd DateTime?
  isTrial         Boolean   @default(false)
  trialEndsAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientService {
  id         String   @id @default(cuid())
  clientId   String
  serviceId  String   // matches ServiceId from constants
  status     String   @default("provisioning") // provisioning | active | paused | canceled
  activatedAt DateTime?
  config     String?  // JSON blob for service-specific config
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, serviceId])
  @@index([clientId])
}

// ─── Leads & Activity ───────────────────────────────────────

model Lead {
  id              String    @id @default(cuid())
  clientId        String
  name            String
  email           String?
  phone           String?
  source          String    @default("website") // website | chatbot | form | phone | referral | voice
  status          String    @default("new") // new | qualified | appointment | won | lost
  notes           String?
  score           Int?      // AI-generated lead score
  stage           String?   // hot | warm | cold
  value           Int?      // estimated deal value in cents
  assignedTo      String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  locationId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])

  @@index([clientId])
  @@index([createdAt])
  @@index([locationId])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // lead_captured | review_received | call_booked | email_sent | content_published | review_response | ad_optimized | seo_update | seasonal_campaign_sent
  title       String
  description String
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

// ─── AI Chatbot ─────────────────────────────────────────────

model ChatbotConfig {
  id           String   @id @default(cuid())
  clientId     String   @unique
  systemPrompt String   // Auto-generated from business info
  greeting     String   @default("Hi! How can I help you today?")
  primaryColor String   @default("#4c85ff")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversations ChatbotConversation[]
}

model ChatbotConversation {
  id          String   @id @default(cuid())
  chatbotId   String
  visitorName String?
  visitorEmail String?
  messages    String   // JSON array of {role, content, timestamp}
  leadCaptured Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatbot ChatbotConfig @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}

// ─── Review Automation ──────────────────────────────────────

model ReviewCampaign {
  id            String   @id @default(cuid())
  clientId      String
  name          String
  customerName  String
  customerEmail String
  customerPhone String?
  status        String   @default("pending") // pending | sent | reminded | completed | opted_out
  reviewUrl     String?  // Google review link
  sentAt        DateTime?
  remindedAt    DateTime?
  completedAt   DateTime?
  rating        Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Content Engine ─────────────────────────────────────────

model ContentJob {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("blog") // blog | social | service_page
  title     String?
  content   String?  // Generated content (markdown)
  keywords  String?  // Comma-separated target keywords
  status    String   @default("queued") // queued | generating | published | failed
  publishAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Email Automation ───────────────────────────────────────

model EmailCampaign {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  subject     String
  body        String   // HTML content
  type        String   @default("drip") // drip | broadcast | reengagement
  status      String   @default("draft") // draft | active | paused | completed
  recipients  Int      @default(0)
  opens       Int      @default(0)
  clicks      Int      @default(0)
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  events EmailEvent[]

  @@index([clientId])
}

// ─── Booking System ─────────────────────────────────────────

model Booking {
  id            String   @id @default(cuid())
  clientId      String
  customerName  String
  customerEmail String?
  customerPhone String?
  serviceType   String?
  startsAt      DateTime
  endsAt        DateTime
  status        String   @default("confirmed") // confirmed | completed | canceled | no_show
  notes         String?
  locationId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])

  @@index([clientId, startsAt])
  @@index([locationId])
}

// ─── Blog ───────────────────────────────────────────────────

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String   // Markdown content
  excerpt         String
  author          String   @default("Sovereign AI Team")
  category        String   // ai-marketing | lead-generation | reviews | chatbots | roi
  tags            String?  // Comma-separated
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([slug])
  @@index([publishedAt])
}

// ─── Onboarding Checklist ───────────────────────────────────

model OnboardingStep {
  id          String    @id @default(cuid())
  clientId    String
  stepKey     String    // gbp | chatbot-greeting | business-hours | first-post | logo
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, stepKey])
}

// ─── Referral Program ───────────────────────────────────────

model ReferralCode {
  id              String   @id @default(cuid())
  clientId        String
  code            String   @unique
  referredClientId String?
  creditCents     Int      @default(0)
  status          String   @default("active") // active | credited | expired
  createdAt       DateTime @default(now())

  client         Client  @relation("referrer", fields: [clientId], references: [id], onDelete: Cascade)
  referredClient Client? @relation("referred", fields: [referredClientId], references: [id])

  @@index([code])
}

// ─── Support Tickets ────────────────────────────────────────

model SupportTicket {
  id          String   @id @default(cuid())
  clientId    String
  subject     String
  description String
  status      String   @default("open") // open | in_progress | resolved | closed
  priority    String   @default("medium") // low | medium | high
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([clientId])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderRole String   // client | admin
  message    String
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  accountId String
  type      String   // lead | review | content | booking | system
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, read])
}

// ─── NPS Survey ─────────────────────────────────────────────

model NPSResponse {
  id          String    @id @default(cuid())
  clientId    String
  score       Int       // 1-10
  feedback    String?
  surveyType  String    // 30day | 90day
  sentAt      DateTime  @default(now())
  respondedAt DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Ad Campaign Management ─────────────────────────────────

model AdCampaign {
  id          String    @id @default(cuid())
  clientId    String
  platform    String    // google | facebook | meta
  externalId  String?
  name        String
  status      String    @default("draft") // draft | active | paused | completed
  budget      Int       @default(0) // cents
  spent       Int       @default(0) // cents
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  costPerLead Int       @default(0) // cents
  startDate   DateTime?
  endDate     DateTime?
  targeting   String?   // JSON
  adCopy      String?   // JSON
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Agency ─────────────────────────────────────────────────

model Agency {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  ownerAccountId  String
  logoUrl         String?
  primaryColor    String?
  accentColor     String?
  customDomain    String?
  starterPrice    Int?     // cents
  growthPrice     Int?     // cents
  empirePrice     Int?     // cents
  stripeAccountId String?
  createdAt       DateTime @default(now())

  @@index([ownerAccountId])
}

// ─── Agent Execution ────────────────────────────────────────

model AgentExecution {
  id             String    @id @default(cuid())
  clientId       String
  agentType      String
  status         String    @default("queued") // queued | running | paused | completed | failed
  input          String?   // JSON
  output         String?   // JSON
  error          String?
  triggeredBy    String?
  startedAt      DateTime?
  completedAt    DateTime?
  totalTokens    Int       @default(0)
  totalCostCents Int       @default(0)
  createdAt      DateTime  @default(now())

  client Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  steps  AgentStep[]

  @@index([clientId])
}

model AgentStep {
  id          String    @id @default(cuid())
  executionId String
  stepNumber  Int
  action      String
  input       String?   // JSON
  output      String?   // JSON
  status      String    @default("pending") // pending | running | completed | failed | skipped
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  tokensUsed  Int       @default(0)
  createdAt   DateTime  @default(now())

  execution AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

// ─── Alert & Monitoring ─────────────────────────────────────

model AlertLog {
  id        String   @id @default(cuid())
  ruleId    String?
  type      String
  title     String
  message   String
  severity  String   // info | warning | error | critical
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([severity])
  @@index([resolved])
}

model AlertRule {
  id        String   @id @default(cuid())
  name      String
  type      String
  config    String?  // JSON
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Anomaly Detection ──────────────────────────────────────

model AnomalyLog {
  id           String   @id @default(cuid())
  clientId     String
  type         String
  severity     String
  title        String
  description  String
  metadata     String?  // JSON
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Governance ─────────────────────────────────────────────

model ApprovalRequest {
  id               String    @id @default(cuid())
  clientId         String
  agentExecutionId String?
  actionType       String
  description      String
  payload          String?   // JSON
  status           String    @default("pending") // pending | approved | rejected | expired
  expiresAt        DateTime?
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

model GovernanceRule {
  id        String   @id @default(cuid())
  clientId  String
  ruleType  String
  isActive  Boolean  @default(true)
  scope     String?
  config    String?  // JSON
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model BudgetTracker {
  id             String   @id @default(cuid())
  clientId       String
  period         String   // daily | monthly
  periodStart    DateTime
  periodEnd      DateTime
  limitCents     Int
  spentCents     Int      @default(0)
  alertThreshold Int?     // percentage (0-100) at which to alert
  createdAt      DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  accountId  String?
  action     String
  resource   String
  resourceId String?
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  @@index([accountId])
  @@index([resource])
}

// ─── Email Queue ────────────────────────────────────────────

model EmailQueue {
  id          String    @id @default(cuid())
  to          String
  subject     String
  html        String
  status      String    @default("pending") // pending | sending | sent | failed | bounced
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  messageId   String?
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([scheduledAt])
}

// ─── Email Event Tracking ───────────────────────────────────

model EmailEvent {
  id         String   @id @default(cuid())
  campaignId String?
  messageId  String
  type       String   // open | click | delivered | bounce | unsubscribe
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  campaign EmailCampaign? @relation(fields: [campaignId], references: [id])

  @@index([messageId])
  @@index([campaignId])
}

// ─── Event-Driven Orchestration ─────────────────────────────

model OrchestrationEvent {
  id         String    @id @default(cuid())
  type       String
  source     String
  payload    String?   // JSON
  clientId   String?
  status     String    @default("pending") // pending | processing | completed | dead_letter
  retryCount Int       @default(0)
  processedAt DateTime?
  claimedAt  DateTime?
  error      String?
  createdAt  DateTime  @default(now())

  @@index([status])
  @@index([type])
}

model EventSubscription {
  id         String   @id @default(cuid())
  eventType  String
  handlerKey String
  isActive   Boolean  @default(true)
  priority   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([eventType])
}

// ─── FSM Integration ────────────────────────────────────────

model FSMConnection {
  id                String    @id @default(cuid())
  clientId          String
  platform          String
  accessToken       String
  refreshToken      String?
  externalAccountId String?
  isActive          Boolean   @default(true)
  syncStatus        String    @default("pending") // pending | syncing | synced | error
  syncError         String?
  lastSyncAt        DateTime?
  config            String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client  Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  syncLogs FSMSyncLog[]

  @@unique([clientId, platform])
}

model FSMSyncLog {
  id           String   @id @default(cuid())
  connectionId String
  direction    String   // inbound | outbound
  entityType   String
  entityId     String?
  externalId   String?
  action       String   // create | update | delete
  status       String   // success | error
  details      String?
  createdAt    DateTime @default(now())

  connection FSMConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

// ─── Franchise Locations ────────────────────────────────────

model FranchiseLocation {
  id               String   @id @default(cuid())
  clientId         String
  name             String
  address          String?
  city             String?
  state            String?
  zip              String?
  phone            String?
  manager          String?
  isActive         Boolean  @default(true)
  leadsThisMonth   Int      @default(0)
  revenueThisMonth Int      @default(0)
  bookingsThisMonth Int     @default(0)
  avgRating        Float    @default(0)
  createdAt        DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Financing ──────────────────────────────────────────────

model FinancingApplication {
  id             String    @id @default(cuid())
  clientId       String
  customerName   String
  customerEmail  String
  customerPhone  String?
  amount         Int       // cents
  term           Int       // months
  apr            Float
  monthlyPayment Int       // cents
  status         String    @default("pending") // pending | approved | declined | funded
  externalId     String?
  prequalAmount  Int?      // cents
  createdAt      DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Invoice ────────────────────────────────────────────────

model Invoice {
  id                   String    @id @default(cuid())
  clientId             String
  customerName         String
  customerPhone        String?
  customerEmail        String?
  description          String
  amount               Int       // cents
  status               String    @default("draft") // draft | sent | paid | overdue | canceled
  stripePaymentLinkId  String?
  stripePaymentLinkUrl String?
  paidAt               DateTime?
  sentAt               DateTime?
  createdAt            DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Job Posting & Recruiting ───────────────────────────────

model JobPosting {
  id             String   @id @default(cuid())
  clientId       String
  title          String
  description    String
  requirements   String   // JSON array stored as string
  compensation   String?
  location       String?
  type           String   @default("full-time")
  status         String   @default("active") // active | closed | draft
  applicantCount Int      @default(0)
  viewCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  applicants Applicant[]

  @@index([clientId])
}

model Applicant {
  id             String   @id @default(cuid())
  jobId          String
  name           String
  email          String
  phone          String?
  experience     String?
  certifications String   // JSON array stored as string
  coverLetter    String?
  aiScore        Int?
  aiSummary      String?
  status         String   @default("new") // new | screening | interviewed | offered | hired | rejected
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── Location ───────────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads    Lead[]
  bookings Booking[]

  @@index([clientId])
}

// ─── MCP API Keys ───────────────────────────────────────────

model MCPApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  accountId  String
  scopes     String    // JSON array stored as string
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  usageLogs MCPUsageLog[]

  @@index([accountId])
}

model MCPUsageLog {
  id         String   @id @default(cuid())
  apiKeyId   String
  tool       String
